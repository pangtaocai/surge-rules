#!name=Airport Traffic Monitor
#!desc=Monitor airport subscription traffic usage with Surge cron script. Replace the URL in argument locally and do not publish your subscription URL.

[Script]
# Runs every day at 09:00. Replace url with your real Surge subscription URL.
机场流量监控 = type=cron,cronexp="0 9 * * *",timeout=30,script-path=https://raw.githubusercontent.com/pangtaocai/surge-rules/master/script/airport-traffic-monitor.js,script-update-interval=86400,argument=name=我的机场;url=https://example.com/your-surge-subscription.conf;warn=80;expire=7
